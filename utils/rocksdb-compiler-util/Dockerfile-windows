# ─────────────────────────────────────────────────────────────
# RocksDB C Library Cross-Compiler — Windows x64 (via MinGW-w64)
# Produces: /output/rocksdb.dll
# ─────────────────────────────────────────────────────────────
# Usage:
#   docker build -f Dockerfile-windows --output "type=local,dest=./output-windows" .
# ─────────────────────────────────────────────────────────────

FROM ubuntu:24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        cmake \
        make \
        gcc \
        libc6-dev \
        g++-mingw-w64-x86-64 \
        gcc-mingw-w64-x86-64 \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Use the POSIX threading variant of MinGW
RUN update-alternatives --set x86_64-w64-mingw32-g++ /usr/bin/x86_64-w64-mingw32-g++-posix 2>/dev/null || true \
    && update-alternatives --set x86_64-w64-mingw32-gcc /usr/bin/x86_64-w64-mingw32-gcc-posix 2>/dev/null || true

ARG ROCKSDB_VERSION=v9.10.0

RUN git clone --depth 1 --branch ${ROCKSDB_VERSION} \
        https://github.com/facebook/rocksdb.git /rocksdb

WORKDIR /rocksdb

# Create a CMake toolchain file for MinGW-w64 cross-compilation
RUN cat > /mingw-toolchain.cmake <<'EOF'
set(CMAKE_SYSTEM_NAME Windows)
set(CMAKE_SYSTEM_PROCESSOR x86_64)

set(CMAKE_C_COMPILER x86_64-w64-mingw32-gcc)
set(CMAKE_CXX_COMPILER x86_64-w64-mingw32-g++)
set(CMAKE_RC_COMPILER x86_64-w64-mingw32-windres)

set(CMAKE_FIND_ROOT_PATH /usr/x86_64-w64-mingw32)
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
EOF

# Build RocksDB as a shared library for Windows
# Disable optional compression libs and tools for a minimal build
RUN cmake -B build \
        -DCMAKE_TOOLCHAIN_FILE=/mingw-toolchain.cmake \
        -DCMAKE_BUILD_TYPE=Release \
        -DWITH_TESTS=OFF \
        -DWITH_BENCHMARK_TOOLS=OFF \
        -DWITH_TOOLS=OFF \
        -DWITH_CORE_TOOLS=OFF \
        -DWITH_GFLAGS=OFF \
        -DWITH_SNAPPY=OFF \
        -DWITH_LZ4=OFF \
        -DWITH_ZLIB=OFF \
        -DWITH_ZSTD=OFF \
        -DWITH_BZ2=OFF \
        -DROCKSDB_BUILD_SHARED=ON \
        -DFAIL_ON_WARNINGS=OFF \
        -DCMAKE_SHARED_LINKER_FLAGS="-static-libgcc -static-libstdc++ -Wl,--allow-multiple-definition" \
    && cmake --build build -j$(nproc) --target rocksdb-shared

# Collect the output DLL
# CMake + MinGW names the shared lib "librocksdb-shared.dll"
RUN mkdir -p /output \
    && cp build/librocksdb-shared.dll /output/rocksdb.dll 2>/dev/null \
    || cp build/librocksdb.dll /output/rocksdb.dll 2>/dev/null \
    || cp build/rocksdb.dll /output/rocksdb.dll 2>/dev/null \
    || (echo "=== Looking for rocksdb DLL ===" && find build -name "*rocksdb*" -type f && exit 1) \
    && echo "=== Output DLLs ===" && ls -lh /output/

# ── Final minimal stage with just the artifacts ──
FROM scratch
COPY --from=builder /output/ /output/